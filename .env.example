# ── Phone-crawler demo backend ───────────────────────────────────────────────
# Absolute URLs to the independently-deployed crawler backend. The crawler
# feature module reads these via import.meta.env (Vite). Copy to `.env.local`
# for local dev, and set the same vars in the Vercel project settings for prod.

# Local dev (backend on port 9000):
VITE_CRAWLER_API=http://localhost:9000/api
VITE_CRAWLER_WS=ws://localhost:9000/ws

# Production example (use https / wss):
# VITE_CRAWLER_API=https://<your-backend-domain>/api
# VITE_CRAWLER_WS=wss://<your-backend-domain>/ws
